# ========================================
# Moka Interview System - Environment Variables
# Copy this file to .env and update values
# ========================================

# ========================================
# Database (PostgreSQL)
# ========================================
POSTGRES_USER=moka
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=moka_db
POSTGRES_PORT=5432

# ========================================
# Backend
# ========================================
BACKEND_PORT=13001
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=7d

# ========================================
# Frontend
# ========================================
FRONTEND_PORT=13000
NEXT_PUBLIC_API_URL=http://localhost:13001

# ========================================
# Nginx (Optional)
# ========================================
# NGINX_PORT=80
# NGINX_SSL_PORT=443
