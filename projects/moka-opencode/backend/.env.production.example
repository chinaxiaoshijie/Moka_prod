# ========================================
# Backend Environment Variables
# ========================================

# Server
NODE_ENV=production
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://moka:moka_password@postgres:5432/moka_db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Application
APP_NAME=Moka Interview System
APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
