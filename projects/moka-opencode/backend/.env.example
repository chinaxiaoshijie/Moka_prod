# Moka 招聘系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 
# 安全提示：
# 1. 永远不要将 .env 文件提交到版本控制
# 2. 生产环境必须使用强随机密钥
# 3. 定期轮换密钥

# ==================== 基础配置 ====================

# 服务端口
PORT=3001

# 服务运行模式 (development | production)
NODE_ENV=development

# API 服务地址
API_URL=http://localhost:3001

# 前端服务地址
FRONTEND_URL=http://localhost:3000

# ==================== 数据库配置 ====================

# PostgreSQL 数据库连接字符串
# 格式：postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moka?schema=public"

# ==================== JWT 认证配置 ====================

# JWT 密钥（必须！生产环境必须使用强随机密钥）
# 生成方法：openssl rand -hex 32
# 最小长度：32 字符
JWT_SECRET="your-super-secret-key-min-32-characters-long"

# JWT 有效期
JWT_EXPIRES_IN=7d

# JWT 刷新令牌有效期
JWT_REFRESH_EXPIRES_IN=30d

# ==================== 邮件服务配置 ====================

# SMTP 服务器地址
EMAIL_HOST=smtp.example.com

# SMTP 端口
EMAIL_PORT=587

# SMTP 用户名
EMAIL_USER=noreply@example.com

# SMTP 密码
EMAIL_PASSWORD=your-email-password

# 发件人地址
EMAIL_FROM=noreply@example.com

# 是否启用 TLS
EMAIL_SECURE=false

# ==================== AI 服务配置 ====================

# OpenAI API 密钥（可选）
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI 模型（可选）
OPENAI_MODEL=gpt-4o-mini

# 阿里云百炼 API 密钥（可选，用于 DeepTutor 集成）
ALIYUN_BAILIAN_API_KEY=your-aliyun-api-key

# ==================== 文件存储配置 ====================

# 上传目录
UPLOAD_DIR=./uploads

# 最大上传文件大小（MB）
MAX_FILE_SIZE=10

# ==================== 日志配置 ====================

# 日志级别 (error | warn | log | http | verbose | debug | silly)
LOG_LEVEL=debug

# 日志格式 (json | simple)
LOG_FORMAT=simple

# ==================== 缓存配置 ====================

# Redis 连接字符串（可选）
# REDIS_URL=redis://localhost:6379

# ==================== 监控配置 ====================

# Sentry DSN（可选）
# SENTRY_DSN=https://your-sentry-dsn

# ==================== 速率限制配置 ====================

# 速率限制时间窗口（秒）
RATE_LIMIT_TTL=60

# 速率限制最大请求数
RATE_LIMIT_MAX=100

# ==================== 第三方服务配置 ====================

# 短信服务（可选）
# SMS_PROVIDER=aliyun
# SMS_API_KEY=your-sms-api-key

# 对象存储（可选）
# OSS_PROVIDER=aliyun
# OSS_ACCESS_KEY=your-oss-access-key
# OSS_SECRET_KEY=your-oss-secret-key
# OSS_BUCKET=your-bucket-name
# OSS_REGION=oss-cn-hangzhou
