// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Seed script
// Run with: bun run prisma:seed

// 系统用户（HR、面试官）
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt 加密
  name      String
  email     String?  // 用于接收通知
  role      Role     @default(INTERVIEWER)
  isActive  Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 作为面试官的面试
  interviewsAsInterviewer Interview[] @relation("InterviewerInterviews")
  // 作为创建者的面试
  createdInterviews    Interview[]  @relation("CreatorInterviews")
  // 面试流程相关
  createdProcesses     InterviewProcess[] @relation("ProcessCreator")
  interviewRounds      InterviewRound[]

  // 反馈
  feedbacks InterviewFeedback[]

  // 通知
  notifications Notification[]
  
  // 上传的简历文件
  uploadedResumes ResumeFile[]
  
  // 被@的记录
  mentionedIn CandidateMention[] @relation("MentionedInterviewer")
  
  // 发起的@记录
  mentionsCreated CandidateMention[] @relation("MentionCreator")
  
  // 状态变更记录
  statusChanges CandidateStatusHistory[]
  
  // 创建的反馈Token
  feedbackTokens FeedbackToken[]
  
  // 飞书用户ID（用于日历同步）
  feishuOuId String?  // 飞书用户open_id

  @@map("users")
}

// 职位
model Position {
  id               String          @id @default(uuid())
  title            String
  description      String?
  requirements     String?
  salaryMin        Int?
  salaryMax        Int?
  headcount        Int             @default(1)
  hiredCount       Int             @default(0)
  inProgressCount  Int             @default(0)
  status           PositionStatus  @default(OPEN)
  location         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  candidates Candidate[]
  interviews Interview[]
  interviewProcesses InterviewProcess[]

  @@map("positions")
}

// 候选人（外部人员，不登录）
model Candidate {
  id         String             @id @default(uuid())
  name       String
  phone      String
  email      String?
  positionId String?
  status     CandidateStatus    @default(PENDING)
  source     CandidateSource?
  resumeUrl  String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  position   Position?  @relation(fields: [positionId], references: [id])
  interviews Interview[]
  interviewProcesses InterviewProcess[]
  
  // 简历文件关联
  resumeFiles ResumeFile[]
  
  // @面试官记录
  mentions   CandidateMention[]
  
  // 状态变更历史
  statusHistory CandidateStatusHistory[]

  @@unique([name, phone]) // 去重约束
  emailLogs    InterviewEmailLog[]
  
  @@map("candidates")
}

// 面试流程（新增）
model InterviewProcess {
  id              String         @id @default(uuid())
  candidateId     String
  positionId      String
  currentRound    Int            @default(1)  // 当前进行到哪一轮
  totalRounds     Int            @default(3)  // 总轮数（默认3轮）
  status          ProcessStatus  @default(IN_PROGRESS)
  hasHRRound      Boolean        @default(true)  // 是否有HR初面（默认有）
  createdById     String
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  
  candidate       Candidate @relation(fields: [candidateId], references: [id])
  position        Position  @relation(fields: [positionId], references: [id])
  createdBy       User      @relation("ProcessCreator", fields: [createdById], references: [id])
  rounds          InterviewRound[]  // 轮次配置
  interviews      Interview[]       // 实际的面试记录

  @@map("interview_processes")
}

// 面试轮次配置（新增）
model InterviewRound {
  id              String   @id @default(uuid())
  processId       String
  roundNumber     Int      // 第几轮（1,2,3）
  interviewerId   String   // 该轮的面试官
  isHRRound       Boolean  @default(false)  // 是否是HR面试
  roundType       String   // HR_SCREENING, TECHNICAL, FINAL
  
  process         InterviewProcess @relation(fields: [processId], references: [id])
  interviewer     User @relation(fields: [interviewerId], references: [id])

  @@unique([processId, roundNumber])
  @@map("interview_rounds")
}

// 面试
model Interview {
  id            String         @id @default(uuid())
  candidateId   String
  positionId    String
  interviewerId String
  type          InterviewType
  format        InterviewFormat
  startTime     DateTime
  endTime       DateTime
  location      String?
  meetingUrl    String?
  meetingNumber String?
  status        InterviewStatus @default(SCHEDULED)
  createdAt     DateTime        @default(now())
  createdById   String?
  
  // 流程相关字段（新增）
  processId     String?
  roundNumber   Int?
  isHRRound     Boolean  @default(false)

  candidate   Candidate @relation(fields: [candidateId], references: [id])
  position    Position  @relation(fields: [positionId], references: [id])
  interviewer User      @relation("InterviewerInterviews", fields: [interviewerId], references: [id])
  createdBy   User?     @relation("CreatorInterviews", fields: [createdById], references: [id])
  process     InterviewProcess? @relation(fields: [processId], references: [id])
  feedbacks   InterviewFeedback[]
  
  // 反馈Token（免登录提交）
  feedbackToken FeedbackToken?
  
  // 飞书日历事件ID（用于同步更新/取消）
  feishuEventId String?

  emailLogs    InterviewEmailLog[]
  
  @@unique([processId, roundNumber])
  @@map("interviews")
}

// 面试反馈
model InterviewFeedback {
  id            String   @id @default(uuid())
  interviewId   String
  interviewerId String
  result        FeedbackResult
  strengths     String?
  weaknesses    String?
  overallRating Int?     // 1-5 星
  notes         String?
  createdAt     DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id])
  interviewer User      @relation(fields: [interviewerId], references: [id])

  @@map("interview_feedbacks")
}

// Enums

enum Role {
  HR
  INTERVIEWER
}

enum PositionStatus {
  OPEN
  PAUSED
  CLOSED
}

enum CandidateStatus {
  PENDING
  SCREENING
  INTERVIEW_1
  INTERVIEW_2
  INTERVIEW_3
  HIRED
  REJECTED
}

enum CandidateSource {
  BOSS
  REFERRAL
  HEADHUNTER
  WEBSITE
}

enum InterviewType {
  INTERVIEW_1 // 初试
  INTERVIEW_2 // 复试
  INTERVIEW_3 // 终试
}

enum InterviewFormat {
  ONLINE  // 线上（腾讯会议）
  OFFLINE // 线下
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// 新增：面试流程状态
enum ProcessStatus {
  IN_PROGRESS    // 进行中
  WAITING_HR     // 等待HR确认（某轮已完成）
  COMPLETED      // 已完成
  CANCELLED      // 已取消
}

enum FeedbackResult {
  PASS
  FAIL
  PENDING
}

// 通知
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  INTERVIEW_REMINDER    // 面试提醒
  FEEDBACK_REQUEST      // 反馈请求
  PROCESS_UPDATE        // 流程更新
  SYSTEM                // 系统通知
}

// 简历文件（支持多版本简历）
model ResumeFile {
  id           String   @id @default(uuid())
  candidateId  String
  fileName     String   // 原始文件名
  fileType     String   // MIME类型 (application/pdf, application/msword等)
  fileSize     Int      // 文件大小(字节)
  filePath     String   // 服务器存储路径
  fileUrl      String   // 访问URL
  uploadedBy   String?  // 上传者ID
  isActive     Boolean  @default(true)  // 是否是当前使用的简历
  uploadedAt   DateTime @default(now())
  
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedByUser User?   @relation(fields: [uploadedBy], references: [id])
  
  @@index([candidateId])
  @@map("resume_files")
}

// @面试官记录
model CandidateMention {
  id            String   @id @default(uuid())
  candidateId   String
  interviewerId String   // 被@的面试官
  mentionedById String   // @操作者
  message       String?  // 附带的留言
  status        MentionStatus @default(PENDING)  // 查看状态
  viewedAt      DateTime? // 查看时间
  createdAt     DateTime @default(now())
  
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewer   User      @relation("MentionedInterviewer", fields: [interviewerId], references: [id])
  mentionedBy   User      @relation("MentionCreator", fields: [mentionedById], references: [id])
  
  @@index([candidateId])
  @@index([interviewerId, status])
  @@map("candidate_mentions")
}

enum MentionStatus {
  PENDING    // 待查看
  VIEWED     // 已查看
  RESPONDED  // 已回复
}

// 面试反馈Token（免登录提交反馈）
model FeedbackToken {
  id            String    @id @default(uuid())
  interviewId   String    @unique  // 一个面试只有一个有效token
  interviewerId String             // 指定面试官
  token         String    @unique   // 随机token字符串
  expiresAt     DateTime           // 过期时间
  usedAt        DateTime?          // 使用时间
  isUsed        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer   User      @relation(fields: [interviewerId], references: [id])
  
  @@index([token])
  @@index([interviewId])
  @@map("feedback_tokens")
}

// 候选人状态变更历史
model CandidateStatusHistory {
  id          String          @id @default(uuid())
  candidateId String
  oldStatus   CandidateStatus?
  newStatus   CandidateStatus
  reason      String?         // 变更原因
  changedBy   String?         // 操作人ID
  relatedInterviewId String?  // 关联的面试ID（如果是面试导致的变更）
  createdAt   DateTime        @default(now())
  
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  changedByUser User?   @relation(fields: [changedBy], references: [id])
  
  @@index([candidateId])
  @@index([createdAt])
  @@map("candidate_status_history")
}

// 邮件发送记录
model InterviewEmailLog {
  id           String   @id @default(uuid())
  interviewId  String
  candidateId  String
  recipientEmail String
  subject      String
  content      String
  sentBy       String
  sentAt       DateTime @default(now())
  status       String   @default("sent")
  errorMessage String?
  
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  @@index([interviewId])
  @@index([candidateId])
  @@index([sentAt])
}

// AI诊断结果（每轮面试前生成）
model AIDiagnosis {
  id           String   @id @default(uuid())
  processId    String   // 面试流程ID
  roundNumber  Int      // 针对第几轮的诊断
  positionId   String?  // 关联职位
  
  // 诊断结果
  matchScore   Int?     // 匹配度 0-100（仅HR轮）
  matchLevel   String?  // high/medium/low
  strengths    String[] // 优势
  weaknesses   String[] // 不足/风险
  suggestions  String[] // 面试建议/重点
  questions    String[] // 建议面试问题（后续轮次）
  summary      String   @default("") // 前轮反馈摘要（后续轮次）
  rawOutput    String   @default("") // AI原始输出
  
  // 输入数据快照（用于重新分析时追溯）
  inputSnapshot Json?   // 记录生成诊断时的输入数据
  
  analyzedAt   DateTime @default(now())
  analyzedBy   String   @default("qwen-plus")
  
  @@unique([processId, roundNumber])  // 每轮只有一个诊断
  @@index([processId])
  @@map("ai_diagnoses")
}

// 系统设置（键值对）
model SystemSetting {
  key         String   @id
  value       String
  description String   @default("")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("system_settings")
}
