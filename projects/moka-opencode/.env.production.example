# ========================================
# Moka Interview System - Environment Variables
# Copy this file to .env and update values
# ========================================

# ========================================
# Database (PostgreSQL)
# ========================================
POSTGRES_USER=moka
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=moka_db
POSTGRES_PORT=5432

# ========================================
# Backend
# ========================================
BACKEND_PORT=13001
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://10.10.2.131:13000

# ========================================
# Frontend
# ========================================
FRONTEND_PORT=13000
NEXT_PUBLIC_API_URL=http://10.10.2.131:13001
FRONTEND_URL=http://10.10.2.131:13000

# ========================================
# Nginx (Optional)
# ========================================
# NGINX_PORT=80
# NGINX_SSL_PORT=443

# ========================================
# Lark CLI (Feishu Calendar Integration)
# ========================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=change_this_to_your_secret
LARK_USER_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Feishu OAuth (User Account Binding)
# ========================================
# 飞书 OAuth 回调地址 — 需要与飞书开放平台配置一致
# 内网环境: http://10.10.2.131:13000/feishu-callback
# 开发环境: http://localhost:13000/feishu-callback
FEISHU_OAUTH_REDIRECT_URI=http://10.10.2.131:13000/feishu-callback
