# Moka 面试系统 Docker 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 服务器配置 ====================
NODE_ENV=production
PORT=3000

# ==================== 数据库配置 ====================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=interview_system
DB_USER=root
# ⚠️ 生产环境必须修改为强密码
MYSQL_ROOT_PASSWORD=interview_system_root_pass_2024

# ==================== JWT 配置 ====================
# ⚠️ 生产环境必须使用至少32字符的随机密钥
# 生成命令: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_EXPIRES=7d

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 生产环境必须修改为强密码
REDIS_PASSWORD=redis_password_2024

# ==================== 邮件服务配置 ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
# ⚠️ 使用应用专用密码，不要使用账户密码
EMAIL_PASS=your-email-app-password

# ==================== 飞书配置（可选）====================
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ==================== 腾讯会议配置（可选）====================
TENCENT_MEETING_SDK_ID=
TENCENT_MEETING_SECRET_ID=
TENCENT_MEETING_SECRET_KEY=

# ==================== 文件上传配置 ====================
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# ==================== 安全配置 ====================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:8080
