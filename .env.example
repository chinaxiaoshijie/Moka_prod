# Moka 面试管理系统 - 环境配置
NODE_ENV=production

# 数据库配置
DATABASE_URL=postgresql://moka:moka123456@localhost:5432/moka_db

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 后端端口
BACKEND_PORT=3001

# 前端端口
FRONTEND_PORT=3000

# API地址（前端使用）
NEXT_PUBLIC_API_URL=http://localhost:3001
